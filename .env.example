# Legal Intake Flow — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── Admin ────────────────────────────────────────────────────────────────────
# Password for the internal admin area at /admin/login
# Must be kept secret — never expose client-side
LIF_ADMIN_PASSWORD=your-strong-admin-password-here

# Secret used to sign admin session tokens (HMAC SHA-256)
# If not set, falls back to LIF_ADMIN_PASSWORD
# Recommended: generate with: openssl rand -base64 48
LIF_ADMIN_SESSION_SECRET=your-random-signing-secret-here

# Secret used to sign partner session tokens (HMAC SHA-256)
# Required — generate with: openssl rand -base64 48
LIF_PARTNER_SESSION_SECRET=your-random-partner-signing-secret-here

# ── DBS Lead Ingestion ───────────────────────────────────────────────────────
# Shared secret used to authenticate POST /api/intake/ingest requests from DBS.
# Must match the value configured in DBS for the LIF ingest endpoint.
# Generate with: openssl rand -base64 48
# Required — the ingest endpoint returns 503 if this is not set.
LIF_DBS_INGEST_SECRET=your-strong-ingest-secret-here


# ── Email / Notifications ───────────────────────────────────────────────────
# Used by Phase 14 admin-triggered email notifications.
# Resend API key. Create in Resend dashboard. Server only.
RESEND_API_KEY=your-resend-api-key-here

# Verified sender address in Resend, for example:
# Legal Intake Flow <notifications@legalintakeflow.com>
LIF_EMAIL_FROM=Legal Intake Flow <notifications@legalintakeflow.com>

# Optional reply-to address for notification emails.
LIF_EMAIL_REPLY_TO=support@legalintakeflow.com

# Public app URL used in emails. Recommended in production.
LIF_APP_URL=https://legalintakeflow.com

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Your Supabase project URL (safe to expose client-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/public key (safe to expose client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Your Supabase service role key — SERVER ONLY, never expose client-side
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
